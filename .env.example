# Carrefour Egypt Scraper Configuration
# Copy this file to .env and fill in your values

# Apify Configuration (for cloud deployment)
APIFY_TOKEN=your_apify_token_here

# Scraper Settings
SITEMAP_URL=https://www.carrefouregypt.com/sitemap.xml
MAX_PAGES_PER_CRAWL=100

# Open Food Facts API (nutrition data)
# No API key required for basic usage
# Rate limit: Be respectful with requests
OFF_API_BASE_URL=https://world.openfoodfacts.org/api/v2

# Playwright Settings
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER=chromium

# Performance Settings
ENABLE_RESOURCE_BLOCKING=true
CACHE_SITEMAP=true
CACHE_NUTRITION=true

# Logging
LOG_LEVEL=INFO
